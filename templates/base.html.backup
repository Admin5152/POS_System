<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hermes Store | {% block title %}{% endblock %}</title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <!-- Inter Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Modern POS CSS -->
    {% load static %}
    <link href="{% static 'css/modern-pos.css' %}" rel="stylesheet">
    
    <style>
        /* Override some Bootstrap styles for modern look */
        .navbar-brand {
            font-weight: 700;
            font-size: 1.5rem;
            background: linear-gradient(135deg, var(--primary-color), #6366f1);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        .main-content {
            transition: var(--transition);
        }
        
        .mobile-menu-toggle {
            display: none;
            position: fixed;
            top: 20px;
            left: 20px;
            z-index: 1001;
            background: var(--primary-color);
            color: white;
            border: none;
            border-radius: 8px;
            padding: 12px;
            cursor: pointer;
        }
        
        @media (max-width: 768px) {
            .mobile-menu-toggle {
                display: block;
            }
        }
    </style>
</head>

<body>
    <!-- Theme Toggle -->
    <button class="theme-toggle" onclick="toggleTheme()" title="Toggle theme">
        <i class="fas fa-moon" id="theme-icon"></i>
    </button>
    
    <!-- Mobile Menu Toggle -->
    <button class="mobile-menu-toggle" onclick="toggleSidebar()">
        <i class="fas fa-bars"></i>
    </button>

    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="{% url 'sales:pos' %}">
                <i class="fas fa-store me-2"></i>Hermes Store
            </a>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <nav class="col-md-3 col-lg-2 d-md-block sidebar collapse" id="sidebar">
                <div class="position-sticky pt-3">
                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a class="nav-link {% if request.resolver_match.app_name == 'reports' %}active{% endif %}"
                                href="{% url 'reports:dashboard' %}">
                                <i class="fas fa-chart-line me-2"></i> Dashboard
                            </a>
                        </li>

                        {% if user.role == 'admin' or user.role == 'manager' %}
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="reportsDropdown" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-file-alt me-2"></i> Reports
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="{% url 'reports:sales' %}">
                                    <i class="fas fa-chart-line me-2"></i>Sales Report
                                </a></li>
                                <li><a class="dropdown-item" href="{% url 'reports:products' %}">
                                    <i class="fas fa-box me-2"></i>Product Sales
                                </a></li>
                                <li><a class="dropdown-item" href="{% url 'reports:inventory' %}">
                                    <i class="fas fa-warehouse me-2"></i>Inventory Report
                                </a></li>
                                <li><a class="dropdown-item" href="{% url 'reports:cashier' %}">
                                    <i class="fas fa-users me-2"></i>Cashier Performance
                                </a></li>
                                <li><a class="dropdown-item" href="{% url 'reports:profit' %}">
                                    <i class="fas fa-chart-pie me-2"></i>Profit Report
                                </a></li>
                            </ul>
                        </li>
                        {% endif %}
        }

        .sidebar .active {
            background-color: #0d6efd;
        }
    </style>
    {% block extra_css %}{% endblock %}
</head>

<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">Hermes Store</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    {% if user.is_authenticated %}
                    <li class="nav-item">
                        <span class="nav-link text-light">Welcome, {{ user.username }} ({{ user.get_role_display
                            }})</span>
                    </li>
                    <li class="nav-item">
                        <form method="post" action="{% url 'accounts:logout' %}">
                            {% csrf_token %}
                            <button class="btn btn-outline-light btn-sm mt-1" type="submit">Logout</button>
                        </form>
                    </li>
                    {% endif %}
                </ul>
            </div>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">
            {% if user.is_authenticated %}
            <!-- Sidebar -->
            <nav class="col-md-3 col-lg-2 d-md-block sidebar collapse">
                <div class="position-sticky pt-3">
                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a class="nav-link {% if request.resolver_match.app_name == 'reports' %}active{% endif %}"
                                href="{% url 'reports:dashboard' %}">
                                <i class="fas fa-chart-line me-2"></i> Dashboard
                            </a>
                        </li>

                        {% if user.role == 'admin' or user.role == 'manager' %}
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="reportsDropdown" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-file-alt me-2"></i> Reports
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="{% url 'reports:sales' %}">
                                    <i class="fas fa-chart-line me-2"></i>Sales Report
                                </a></li>
                                <li><a class="dropdown-item" href="{% url 'reports:products' %}">
                                    <i class="fas fa-box me-2"></i>Product Sales
                                </a></li>
                                <li><a class="dropdown-item" href="{% url 'reports:inventory' %}">
                                    <i class="fas fa-warehouse me-2"></i>Inventory Report
                                </a></li>
                                <li><a class="dropdown-item" href="{% url 'reports:cashier' %}">
                                    <i class="fas fa-users me-2"></i>Cashier Performance
                                </a></li>
                                <li><a class="dropdown-item" href="{% url 'reports:profit' %}">
                                    <i class="fas fa-chart-pie me-2"></i>Profit Report
                                </a></li>
                            </ul>
                        </li>
                        {% endif %}

                        <li class="nav-item">
                            <a class="nav-link {% if request.resolver_match.app_name == 'sales' and request.resolver_match.url_name == 'pos' %}active{% endif %}"
                                href="{% url 'sales:pos' %}">
                                <i class="fas fa-cash-register me-2"></i> POS Terminal
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link {% if request.resolver_match.app_name == 'sales' and request.resolver_match.url_name == 'returns' %}active{% endif %}"
                                href="{% url 'sales:returns' %}">
                                <i class="fas fa-undo me-2"></i> Process Returns
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link {% if request.resolver_match.app_name == 'products' %}active{% endif %}"
                                href="{% url 'products:list' %}">
                                <i class="fas fa-box me-2"></i> Products
                            </a>
                        </li>

                        {% if user.role == 'admin' %}
                        <li class="nav-item">
                            <a class="nav-link {% if request.resolver_match.app_name == 'inventory' %}active{% endif %}"
                                href="{% url 'inventory:list' %}">
                                <i class="fas fa-warehouse me-2"></i> Inventory
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link {% if request.resolver_match.app_name == 'customers' %}active{% endif %}"
                                href="{% url 'customers:list' %}">
                                <i class="fas fa-users me-2"></i> Customers
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link {% if request.resolver_match.url_name == 'employee_list' %}active{% endif %}"
                                href="{% url 'accounts:employee_list' %}">
                                <i class="fas fa-users-cog me-2"></i> Employees
                            </a>
                        </li>
                        {% elif user.role == 'manager' %}
                        <li class="nav-item">
                            <a class="nav-link {% if request.resolver_match.app_name == 'inventory' %}active{% endif %}"
                                href="{% url 'inventory:list' %}">
                                <i class="fas fa-warehouse me-2"></i> Inventory View
                            </a>
                        </li>
                        {% elif user.role == 'cashier' %}
                        <li class="nav-item">
                            <a class="nav-link {% if request.resolver_match.app_name == 'inventory' %}active{% endif %}"
                                href="{% url 'inventory:list' %}">
                                <i class="fas fa-warehouse me-2"></i> Inventory View
                            </a>
                        </li>
                        {% endif %}
                    </ul>
                </div>
            </nav>
            {% endif %}

            <!-- Main Content -->
            <main
                class="{% if user.is_authenticated %}col-md-9 ms-sm-auto col-lg-10 px-md-4{% else %}col-12{% endif %} mt-4">
                {% if messages %}
                {% for message in messages %}
                <div class="alert alert-{{ message.tags }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
                {% endfor %}
                {% endif %}

                {% block content %}
                {% endblock %}
            </main>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    {% block extra_js %}{% endblock %}
</body>

</html>